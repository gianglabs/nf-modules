nextflow_process {

    name "Test Process BWA_MEM2"
    script "../main.nf"
    process "BWA_MEM2"

    tag "modules"
    tag "modules_gianglabs"
    tag "bwa"
    tag "bwa/mem2"

    test("homo_sapiens - paired_end") {

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', sample: 'test', lane: 'L001', read_group: 'test_L001' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/fastq/HG002_subset_R1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/fastq/HG002_subset_R2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = Channel.of(file(params.modules_testdata_base_path + 'genomics/homo_sapiens/reference/chr22.fasta', checkIfExists: true))
                input[2] = Channel.of(file(params.modules_testdata_base_path + 'genomics/homo_sapiens/reference/chr22.fasta.fai', checkIfExists: true))
                input[3] = Channel.of(file(params.modules_testdata_base_path + 'genomics/homo_sapiens/reference/chr22.dict', checkIfExists: true))
                input[4] = Channel.fromPath(params.modules_testdata_base_path + 'genomics/homo_sapiens/reference/chr22.fasta.*').collect()
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
